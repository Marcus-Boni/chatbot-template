OPENAI_API_KEY=
DATABASE_URL=
TRANSCRIPTS_DIR=

# Azure DevOps — geração de Work Items a partir das reuniões (opcional).
# A integração se desativa sozinha se estas variáveis não estiverem definidas.
# AZURE_DEVOPS_PAT precisa do escopo "Work Items (Read & write)".
AZURE_DEVOPS_ORG_URL=        # ex.: https://dev.azure.com/minha-org
AZURE_DEVOPS_PROJECT=        # nome do projeto
AZURE_DEVOPS_PAT=            # Personal Access Token (fica só no servidor)
AZURE_DEVOPS_DEFAULT_WORK_ITEM_TYPE=Task
AZURE_DEVOPS_AREA_PATH=      # opcional, ex.: Projeto\\Time
AZURE_DEVOPS_ITERATION_PATH= # opcional, ex.: Projeto\\Sprint 1
